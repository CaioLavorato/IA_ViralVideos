{
  "ConnectionStrings": {
    "Default": "Data Source=data/videosaas.db"
  },
  "Ollama": {
    "BaseUrl": "http://host.docker.internal:11434",
    "Model": "qwen2.5:7b",
    "TimeoutSeconds": 120
  },
  "ComfyUI": {
    "BaseUrl": "http://host.docker.internal:8188",
    "TimeoutSeconds": 1800,
    "Steps": 10,
    "DimensionScale": 0.5,
    "Width": 0,
    "Height": 0
  },
  "Media": {
    "RootPath": "/app/media",
    "DockerBindRootPath": "/app/media",
    "PiperImage": "rhasspy/wyoming-piper:latest",
    "FfmpegImage": "jrottenberg/ffmpeg:latest",
    "PiperModelsPath": "/app/models/piper"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "AllowedHosts": "*"
}
